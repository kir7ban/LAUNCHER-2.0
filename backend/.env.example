# ─── Azure OpenAI ─────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o

# ─── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080

# Frontend CORS origins (comma-separated).
# In production: set to your Azure Static Web App URL.
# Example: https://my-app.azurestaticapps.net
FRONTEND_URLS=http://localhost:5173,http://localhost:3000

# ─── MCP Agent Configuration ──────────────────────────────────────────────────
MCP_AGENTS_CONFIG=agents.json

# URL of the deployed CyberAgent MCP endpoint.
# Overrides the ${CYBERAGENT_URL:-...} placeholder in agents.json.
# Local dev default: http://localhost:8000/mcp
# Azure Container Apps (internal): https://ca-rbin-bdo-cyberagent.internal/mcp
CYBERAGENT_URL=http://localhost:8000/mcp

# ─── Orchestrator Settings ────────────────────────────────────────────────────
ORCHESTRATOR_MAX_TURNS=5
ORCHESTRATOR_TIMEOUT_MS=90000

# How often (minutes) the background task re-fetches live routing knowledge
# from connected agents (0 = fetch at startup only, no background refresh).
KNOWLEDGE_REFRESH_INTERVAL_MINUTES=30

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
